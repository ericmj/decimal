+  @decimal_max_precision 65
+  @decimal_max_scale 30
+  @decimal_max_text_bytes @decimal_max_precision + 2
+  @decimal_to_string_opts [max_output_digits: @decimal_max_precision]
+  @decimal_max_coefficient :erlang.binary_to_integer(
+                             "1" <> String.duplicate("0", @decimal_max_precision)
+                           )
+
+  defguardp common_mysql_decimal?(sign, coef, exp)
+            when (sign == 1 or sign == -1) and is_integer(coef) and coef >= 0 and
+                   is_integer(exp) and exp >= -@decimal_max_scale and exp <= 0 and
+                   coef < @decimal_max_coefficient
+

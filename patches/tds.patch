+  defp decimal_precision_scale!(%Decimal{coef: coef, exp: exp}) do
+    digits = decimal_coefficient_digits!(coef)
+    {precision, scale} = decimal_precision_scale!(digits, exp)
+
+    validate_decimal_type_shape!(precision, scale)
+
+    {precision, scale}
+  end
+
+  defp decimal_precision_scale!(_digits, exp)
+       when is_integer(exp) and exp >= @max_decimal_precision do
+    raise_decimal_precision_overflow!()
+  end
+
+  defp decimal_precision_scale!(digits, exp) when is_integer(exp) and exp >= 0 do
+    {digits + exp, 0}
+  end
+
+  defp decimal_precision_scale!(_digits, exp)
+       when is_integer(exp) and exp < -@max_decimal_precision do
+    raise_decimal_precision_overflow!()
+  end
+
+  defp decimal_precision_scale!(digits, exp) when is_integer(exp) do
+    scale = -exp
+    precision = max(digits, scale)
+
+    {precision, scale}
+  end
+
+  defp decimal_precision_scale!(_digits, _exp) do
+    raise ArgumentError, "decimal exponent must be an integer"
+  end
+
+  defp decimal_coefficient(%Decimal{coef: coef}), do: coef
+
+  defp validate_decimal_value!(%Decimal{} = value) do
+    _ = decimal_precision_scale!(value)
+    :ok
+  end
+
+  defp decimal_coefficient_digits!(coef)
+       when is_integer(coef) and coef >= 0 and coef < @decimal_coef_limit do
+    coef
+    |> Integer.to_string()
+    |> byte_size()
+  end
+
+  defp decimal_coefficient_digits!(coef) when is_integer(coef) and coef >= @decimal_coef_limit do
+    raise_decimal_precision_overflow!()
+  end
+
+  defp decimal_coefficient_digits!(_coef) do
+    raise ArgumentError, "decimal values must be finite"
+  end
+
+  defp decimal_scaled_integer(%Decimal{coef: coef, exp: exp}) when exp > 0 do
+    decimal_coefficient_digits!(coef)
+    coef * decimal_power_of_10(exp)
+  end
+
+  defp decimal_scaled_integer(%Decimal{coef: coef}) do
+    decimal_coefficient_digits!(coef)
+    coef
+  end
+
+  defp decimal_power_of_10(exp) when exp >= 0 and exp < @max_decimal_precision do
+    elem(@decimal_powers_of_10, exp)
+  end
+
+  defp decimal_power_of_10(_exp) do
+    raise_decimal_precision_overflow!()
+  end
+
+  defp decimal_sign(%Decimal{sign: -1}), do: 0
+  defp decimal_sign(%Decimal{sign: 1}), do: 1
+
+  defp decimal_sign(%Decimal{}) do
+    raise ArgumentError, "decimal sign must be 1 or -1"
+  end
+
+  defp decimal_data_length!(precision) do
+    validate_decimal_type_shape!(precision, 0)
+
+    cond do
+      precision <= 9 -> 4
+      precision <= 19 -> 8
+      precision <= 28 -> 12
+      precision <= @max_decimal_precision -> 16
+    end
+  end
+
+  defp validate_decimal_type_shape!(precision, scale)
+       when is_integer(precision) and is_integer(scale) do
+    cond do
+      precision < 1 ->
+        raise ArgumentError,
+              "SQL Server decimal precision must be between 1 and #{@max_decimal_precision}"
+
+      precision > @max_decimal_precision ->
+        raise_decimal_precision_overflow!()
+
+      scale < 0 ->
+        raise ArgumentError, "SQL Server decimal scale must be between 0 and the precision"
+
+      scale > precision ->
+        raise ArgumentError, "SQL Server decimal scale cannot exceed precision"
+
+      true ->
+        :ok
+    end
+  end
+
+  defp validate_decimal_type_shape!(_precision, _scale) do
+    raise ArgumentError, "SQL Server decimal precision and scale must be integers"
+  end
+
+  defp validate_decimal_sign!(sign) when sign in [0, 1], do: :ok
+
+  defp validate_decimal_sign!(sign) do
+    raise ArgumentError, "Sign value out of range. Expected 0 or 1, got #{inspect(sign)}"
+  end
+
+  defp validate_decimal_data_length!(precision, value) do
+    max_size = decimal_data_length!(precision)
+
+    if byte_size(value) > max_size do
+      raise ArgumentError,
+            "SQL Server decimal payload exceeds #{max_size} bytes for precision #{precision}"
+    end
+  end
+
+  defp raise_decimal_precision_overflow! do
+    raise ArgumentError,
+          "SQL Server decimal precision exceeds maximum of #{@max_decimal_precision}"
+  end

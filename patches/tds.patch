diff --git a/test/types/types_test.exs b/test/types/types_test.exs
index 100ee1b..9217fb3 100644
--- a/test/types/types_test.exs
+++ b/test/types/types_test.exs
@@ -149,6 +149,127 @@ defmodule Tds.TypesTest do
       assert sign == 1
       assert :binary.decode_unsigned(value_binary, :little) == 1
     end
+
+    test "encodes decimal at SQL Server maximum precision", _context do
+      value = Decimal.new("99999999999999999999999999999999999999")
+      attr = [precision: 38, scale: 0]
+
+      assert <<byte_len>> <> <<sign>> <> value_binary =
+               Tds.Types.encode_data(@tds_data_type_decimaln, value, attr)
+
+      assert byte_len == 17
+      assert sign == 1
+
+      assert :binary.decode_unsigned(value_binary, :little) ==
+               String.to_integer(String.duplicate("9", 38))
+    end
+
+    test "encodes decimal at SQL Server maximum scale", _context do
+      value = Decimal.new("1E-38")
+      attr = [precision: 38, scale: 38]
+
+      assert <<byte_len>> <> <<sign>> <> value_binary =
+               Tds.Types.encode_data(@tds_data_type_decimaln, value, attr)
+
+      assert byte_len == 17
+      assert sign == 1
+      assert :binary.decode_unsigned(value_binary, :little) == 1
+    end
+
+    test "rejects decimals over SQL Server maximum precision before encoding", _context do
+      value = Decimal.new("1E+38")
+      attr = [precision: 38, scale: 0]
+
+      assert_raise ArgumentError, ~r/SQL Server decimal precision/, fn ->
+        Tds.Types.encode_data(@tds_data_type_decimaln, value, attr)
+      end
+    end
+
+    test "rejects invalid decimal metadata before encoding", _context do
+      value = Decimal.new("1")
+
+      assert_raise ArgumentError, ~r/SQL Server decimal precision/, fn ->
+        Tds.Types.encode_data(@tds_data_type_decimaln, value, precision: 39, scale: 0)
+      end
+
+      assert_raise ArgumentError, ~r/SQL Server decimal scale cannot exceed precision/, fn ->
+        Tds.Types.encode_data(@tds_data_type_decimaln, value, precision: 38, scale: 39)
+      end
+    end
+  end
+
+  describe "encode_param_descriptor/1 for decimal values" do
+    test "keeps boundary descriptors for valid decimal values" do
+      assert Tds.Types.encode_param_descriptor(%Parameter{
+               name: "@1",
+               type: :decimal,
+               value: Decimal.new("1E+37")
+             }) == "@1 decimal(38, 0)"
+
+      assert Tds.Types.encode_param_descriptor(%Parameter{
+               name: "@1",
+               type: :decimal,
+               value: Decimal.new("1E-37")
+             }) == "@1 decimal(38, 37)"
+
+      assert Tds.Types.encode_param_descriptor(%Parameter{
+               name: "@1",
+               type: :decimal,
+               value: Decimal.new("1E-38")
+             }) == "@1 decimal(38, 38)"
+
+      assert Tds.Types.encode_param_descriptor(%Parameter{
+               name: "@1",
+               type: :decimal,
+               value: Decimal.new("0.0001")
+             }) == "@1 decimal(4, 4)"
+    end
+
+    test "rejects decimal and numeric descriptors over SQL Server maximum precision" do
+      for type <- [:decimal, :numeric] do
+        assert_raise ArgumentError, ~r/SQL Server decimal precision/, fn ->
+          Tds.Types.encode_param_descriptor(%Parameter{
+            name: "@1",
+            type: type,
+            value: Decimal.new("1E+5000")
+          })
+        end
+      end
+    end
+
+    test "rejects decimal and numeric data types over SQL Server maximum precision" do
+      for type <- [:decimal, :numeric] do
+        assert_raise ArgumentError, ~r/SQL Server decimal precision/, fn ->
+          Tds.Types.encode_data_type(%Parameter{
+            name: "@1",
+            type: type,
+            value: Decimal.new("1E+5000")
+          })
+        end
+      end
+    end
+  end
+
+  describe "decode_decimal/3" do
+    test "decodes SQL Server maximum scale boundary" do
+      assert Tds.Types.decode_decimal(38, 38, <<1, 1>>) == Decimal.new("1E-38")
+    end
+
+    test "rejects decimal metadata outside SQL Server limits" do
+      assert_raise ArgumentError, ~r/SQL Server decimal precision/, fn ->
+        Tds.Types.decode_decimal(39, 0, <<1, 0>>)
+      end
+
+      assert_raise ArgumentError, ~r/SQL Server decimal scale cannot exceed precision/, fn ->
+        Tds.Types.decode_decimal(38, 39, <<1, 0>>)
+      end
+    end
+
+    test "rejects decimal data over the byte length for the precision" do
+      assert_raise ArgumentError, ~r/SQL Server decimal payload exceeds 4 bytes/, fn ->
+        Tds.Types.decode_decimal(9, 0, <<1, 0::size(5)-unit(8)>>)
+      end
+    end
   end
 
   describe "inserting decimal values into the database" do

     IO.iodata_to_binary(
       SQL.insert(prefix, table, header, rows, on_conflict, returning, placeholders)
@@ -889,6 +897,25 @@ defmodule Ecto.Adapters.PostgresTest do
 
     query = "schema" |> where(foo: 123.0) |> select([], true) |> plan()
     assert all(query) == ~s{SELECT TRUE FROM "schema" AS s0 WHERE (s0."foo" = 123.0::float)}
+
+    query = decimal_literal_query(Decimal.new("123.45"))
+    assert all(query) == ~s{SELECT TRUE FROM "schema" AS s0 WHERE (s0."foo" = 123.45)}
+  end
+
+  test "decimal literals reject values outside PostgreSQL numeric range" do
+    if function_exported?(Decimal, :to_string, 3) do
+      assert_raise Ecto.QueryError, ~r/configured maximum/, fn ->
+        %Decimal{sign: 1, coef: 1, exp: 1_000_000}
+        |> decimal_literal_query()
+        |> all()
+      end
+    end
+
+    assert_raise Ecto.QueryError, ~r/maximum of 16383 fractional digits/, fn ->
+      %Decimal{sign: 1, coef: 1, exp: -1_000_000}
+      |> decimal_literal_query()
+      |> all()
+    end
   end
 
   test "aliasing a selected value with selected_as/2" do

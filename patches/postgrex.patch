diff --git a/test/numeric_test.exs b/test/numeric_test.exs
new file mode 100644
index 0000000..fe8aaf4
--- /dev/null
+++ b/test/numeric_test.exs
@@ -0,0 +1,79 @@
+defmodule Postgrex.Extensions.NumericTest do
+  use ExUnit.Case, async: true
+
+  alias Postgrex.Extensions.Numeric
+
+  @max_integer_digits 131_072
+  @max_scale 16_383
+  @max_integer_groups div(@max_integer_digits, 4)
+  @max_fractional_groups div(@max_scale + 3, 4)
+  @max_numeric_digits @max_integer_groups + @max_fractional_groups
+  @max_weight @max_integer_groups - 1
+
+  test "encode and decode PostgreSQL maximum numeric shape" do
+    decimal = decimal_with_digits(@max_integer_digits + @max_scale, -@max_scale)
+
+    encoded = Numeric.encode_numeric(decimal) |> IO.iodata_to_binary()
+
+    assert <<@max_numeric_digits::16, @max_weight::signed-16, 0::16, @max_scale::16, _::binary>> =
+             encoded
+
+    assert Numeric.decode_numeric(encoded) == decimal
+  end
+
+  test "encode and decode compact maximum integer shape" do
+    decimal = Decimal.new(1, 1, @max_integer_digits - 1)
+
+    encoded = Numeric.encode_numeric(decimal) |> IO.iodata_to_binary()
+    assert <<1::16, @max_weight::signed-16, 0::16, 0::16, 1000::16>> = encoded
+
+    assert Decimal.equal?(Numeric.decode_numeric(encoded), decimal)
+  end
+
+  test "encode and decode maximum scale" do
+    decimal = Decimal.new(1, 1, -@max_scale)
+    weight = -@max_fractional_groups
+
+    encoded = Numeric.encode_numeric(decimal) |> IO.iodata_to_binary()
+    assert <<1::16, ^weight::signed-16, 0::16, @max_scale::16, 10::16>> = encoded
+
+    assert Numeric.decode_numeric(encoded) == decimal
+  end
+
+  test "encode rejects numeric values beyond PostgreSQL limits" do
+    assert_raise DBConnection.EncodeError, ~r/maximum scale #{@max_scale}/, fn ->
+      Numeric.encode_numeric(Decimal.new(1, 1, -(@max_scale + 1)))
+    end
+
+    assert_raise DBConnection.EncodeError, ~r/maximum is #{@max_integer_digits}/, fn ->
+      Numeric.encode_numeric(Decimal.new(1, 1, @max_integer_digits))
+    end
+  end
+
+  test "decode rejects numeric values beyond PostgreSQL limits" do
+    over_max_scale = @max_scale + 1
+
+    assert_raise ArgumentError, ~r/maximum scale #{@max_scale}/, fn ->
+      Numeric.decode_numeric(<<0::16, 0::signed-16, 0::16, over_max_scale::16>>)
+    end
+
+    over_max_digits = @max_numeric_digits + 1
+    over_max_digits_bin = :binary.copy(<<0::16>>, over_max_digits)
+
+    assert_raise ArgumentError, ~r/maximum is #{@max_numeric_digits}/, fn ->
+      Numeric.decode_numeric(
+        <<over_max_digits::16, 0::signed-16, 0::16, 0::16, over_max_digits_bin::binary>>
+      )
+    end
+
+    assert_raise ArgumentError, ~r/more fractional digits/, fn ->
+      Numeric.decode_numeric(
+        <<1::16, -(@max_fractional_groups + 1)::signed-16, 0::16, @max_scale::16, 1::16>>
+      )
+    end
+  end
+
+  defp decimal_with_digits(digits, exp) do
+    Decimal.new(1, String.duplicate("9", digits) |> :erlang.binary_to_integer(), exp)
+  end
+end
